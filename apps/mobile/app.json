{
  "expo": {
    "name": "ECHO//SELF",
    "slug": "echo-self",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/icons/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/your-project-id"
    },
    "runtimeVersion": { "policy": "appVersion" },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ai.echoself.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "ECHO//SELF uses your microphone to record voice journal entries.",
        "NSPhotoLibraryUsageDescription": "ECHO//SELF saves your identity cards to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "ai.echoself.app",
      "permissions": ["RECORD_AUDIO", "READ_MEDIA_IMAGES"]
    },
    "plugins": [
      ["expo-secure-store"],
      ["expo-av"],
      ["react-native-onesignal", { "mode": "production" }],
      ["@stripe/stripe-react-native", { "merchantIdentifier": "merchant.ai.echoself" }]
    ],
    "extra": {
      "eas": { "projectId": "your-eas-project-id" }
    }
  }
}
