# Supabase — get from https://app.supabase.com/project/<your-project>/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Sentry — get from https://sentry.io (optional, leave blank to disable)
EXPO_PUBLIC_SENTRY_DSN=

# PostHog — get from https://app.posthog.com (optional, leave blank to disable)
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Stripe — for Paywall screen (optional, leave blank to disable payments)
EXPO_PUBLIC_STRIPE_CHECKOUT_URL=https://buy.stripe.com/your-link
