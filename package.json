{
  "name": "echo-self",
  "version": "0.0.1",
  "private": true,
  "description": "ECHO//SELF \u2014 AI-native identity operating system",
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo clean && find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "validate:setup": "tsx scripts/validate-setup.ts",
    "validate:migrations": "tsx scripts/validate-migrations.ts",
    "db:types": "supabase gen types typescript --local > packages/supabase/src/types/database.ts"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5",
    "tsx": "^4.19.2",
    "dotenv": "^16.4.7"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
