{
  "crons": [
    {
      "path": "/api/cron/process-memory-embeddings",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/generate-daily-insight",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/send-streak-reminders",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/cron/update-future-self-predictions",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/cleanup-expired-sessions",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/billing-usage-sync",
      "schedule": "0 1 * * *"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
