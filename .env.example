# =============================================================================
# ECHO//SELF — Environment Variable Reference
# =============================================================================
# Copy this file to .env.local for development
# NEVER commit .env.local or any file with real secrets
#
# Security Classification:
#   [PUBLIC]  — Safe to expose in browser (use NEXT_PUBLIC_ prefix)
#   [PRIVATE] — Server-side only
#   [SECRET]  — High sensitivity, rotate regularly
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE
# -----------------------------------------------------------------------------
# [PUBLIC] Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# [PUBLIC] Supabase anonymous key (safe for client-side)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# [SECRET] Supabase service role key — server/edge functions only, NEVER in client
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# [PRIVATE] Direct database connection URL (for migrations)
DATABASE_URL=postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# OPENAI
# -----------------------------------------------------------------------------
# [SECRET] OpenAI API key — server/edge functions only
OPENAI_API_KEY=sk-...

# [PRIVATE] OpenAI organization ID
OPENAI_ORG_ID=org-...

# [PRIVATE] OpenAI model identifiers
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_WHISPER_MODEL=whisper-1

# [PRIVATE] Max tokens for different AI tasks
OPENAI_MAX_TOKENS_REFLECTION=2048
OPENAI_MAX_TOKENS_INSIGHT=512
OPENAI_MAX_TOKENS_FUTURE_SELF=1024

# [PRIVATE] Enable OpenAI debug logging in development
OPENAI_DEBUG=false

# -----------------------------------------------------------------------------
# STRIPE
# -----------------------------------------------------------------------------
# [PUBLIC] Stripe publishable key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_...

# [SECRET] Stripe secret key — server only
STRIPE_SECRET_KEY=sk_...

# [SECRET] Stripe webhook signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# [PRIVATE] Stripe price IDs
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...

# [PRIVATE] Trial period in days
STRIPE_TRIAL_DAYS=14

# -----------------------------------------------------------------------------
# ONESIGNAL (Push Notifications)
# -----------------------------------------------------------------------------
# [PUBLIC] OneSignal app ID
NEXT_PUBLIC_ONESIGNAL_APP_ID=...

# [SECRET] OneSignal REST API key — server only
ONESIGNAL_API_KEY=...

# -----------------------------------------------------------------------------
# VERCEL
# -----------------------------------------------------------------------------
# [PRIVATE] Vercel team ID (for drain/deployment APIs)
VERCEL_TEAM_ID=team_...

# [SECRET] Vercel API token
VERCEL_TOKEN=...

# [PRIVATE] Drain signing secret for log drain signature verification
DRAIN_SECRET=...

# -----------------------------------------------------------------------------
# SENTRY (Error Tracking)
# -----------------------------------------------------------------------------
# [PUBLIC] Sentry DSN — safe for client-side
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# [PRIVATE] Sentry auth token (for source map upload)
SENTRY_AUTH_TOKEN=...

# [PRIVATE] Sentry organization and project
SENTRY_ORG=echo-self
SENTRY_PROJECT=echo-self-app

# -----------------------------------------------------------------------------
# POSTHOG (Analytics)
# -----------------------------------------------------------------------------
# [PUBLIC] PostHog API key
NEXT_PUBLIC_POSTHOG_KEY=phc_...

# [PUBLIC] PostHog host (use EU host for GDPR compliance)
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# -----------------------------------------------------------------------------
# CLOUDFLARE
# -----------------------------------------------------------------------------
# [PRIVATE] Cloudflare account ID
CLOUDFLARE_ACCOUNT_ID=...

# [SECRET] Cloudflare API token
CLOUDFLARE_API_TOKEN=...

# [PRIVATE] Cloudflare zone ID
CLOUDFLARE_ZONE_ID=...

# -----------------------------------------------------------------------------
# APP CONFIGURATION
# -----------------------------------------------------------------------------
# [PUBLIC] App environment
NEXT_PUBLIC_APP_ENV=development

# [PUBLIC] App URL (current deployment)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# [PRIVATE] App name
APP_NAME=ECHO//SELF

# [PRIVATE] Feature flags override (comma-separated)
# Example: FEATURE_FLAGS=future-self-v2,experimental-voice
FEATURE_FLAGS=

# [PRIVATE] Rate limiting (requests per minute per user)
RATE_LIMIT_AI_RPM=10
RATE_LIMIT_API_RPM=100

# -----------------------------------------------------------------------------
# INTERNAL SERVICES
# -----------------------------------------------------------------------------
# [PRIVATE] Cron job secret for authenticated cron endpoints
CRON_SECRET=...

# [SECRET] Internal API secret for service-to-service calls
INTERNAL_API_SECRET=...

# [PRIVATE] Maximum vector embedding dimensions
VECTOR_DIMENSIONS=3072

# [PRIVATE] Memory retrieval top-k count
MEMORY_RETRIEVAL_TOP_K=20

# [PRIVATE] Similarity threshold for memory retrieval (0.0 - 1.0)
MEMORY_SIMILARITY_THRESHOLD=0.78
